                                                    <a href="#"
                                                       class="font-mono text-[.6rem] tracking-widest uppercase text-rosy-mid hover:text-bg-deep border-b border-transparent hover:border-rosy-mid pb-0.5 transition-all duration-300 no-underline">Resume</a>
                                                </div>
                                            </section>



                                            <!-- Hover preview -->
                                            <div class="proj-preview" id="projPreview">
                                                <div class="prev-inner" id="prevInner"></div>
                                            </div>

                                            <script>
                                                    // Cursor
                                                    const cur = document.getElementById('cursor');
                                                    const ring = document.getElementById('cursorRing');
                                                    let mx = 0, my = 0, rx = 0, ry = 0;
                                                    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; cur.style.left = mx - 5 + 'px'; cur.style.top = my - 5 + 'px'; });
                                                    (function loop() { rx += (mx - rx - 19) * .12; ry += (my - ry - 19) * .12; ring.style.left = rx + 'px'; ring.style.top = ry + 'px'; requestAnimationFrame(loop); })();
                                                    document.querySelectorAll('a,button,.proj-item,div[class*="hover:border-rosy"],div[class*="group"]').forEach(el => {
                                                        el.addEventListener('mouseenter', () => { cur.classList.add('expand'); ring.classList.add('expand'); });
                                                        el.addEventListener('mouseleave', () => { cur.classList.remove('expand'); ring.classList.remove('expand'); });
                                                    });

                                                    // Nav scroll
                                                    const nav = document.getElementById('navbar');
                                                    window.addEventListener('scroll', () => {
                                                        if (window.scrollY > 50) { nav.style.background = 'rgba(45,27,27,0.96)'; nav.style.backdropFilter = 'blur(14px)'; nav.style.borderBottom = '1px solid rgba(188,143,143,.2)'; }
                                                        else { nav.style.background = ''; nav.style.backdropFilter = ''; nav.style.borderBottom = ''; }
                                                    });

                                                    // Reveal
                                                    const io = new IntersectionObserver(es => es.forEach(e => e.isIntersecting && e.target.classList.add('visible')), { threshold: .1 });
                                                    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

                                                    // Counters
                                                    const co = new IntersectionObserver(es => es.forEach(e => {
                                                        if (!e.isIntersecting) return;
                                                        const el = e.target, t = +el.dataset.count; let c = 0;
                                                        const iv = setInterval(() => { c += t / 50; if (c >= t) { c = t; clearInterval(iv); } el.textContent = Math.floor(c) + '+'; }, 30);
                                                        co.unobserve(el);
                                                    }), { threshold: .5 });
                                                    document.querySelectorAll('[data-count]').forEach(el => co.observe(el));

                                                    // Project hover preview
                                                    const preview = document.getElementById('projPreview');
                                                    const prevInner = document.getElementById('prevInner');
                                                    document.querySelectorAll('.proj-item').forEach((item, i) => {
                                                        const title = item.querySelector('.font-display');
                                                        item.addEventListener('mouseenter', () => { if (title) { prevInner.textContent = title.textContent; prevInner.style.background = '#BC8F8F'; prevInner.style.color = '#FFF5EE'; preview.classList.add('on'); } });
                                                        item.addEventListener('mouseleave', () => preview.classList.remove('on'));
                                                        item.addEventListener('mousemove', e => { preview.style.left = (e.clientX + 18) + 'px'; preview.style.top = (e.clientY - 80) + 'px'; });
                                                    });
                                                    function openDetail(id) {
  window.location.href = 'project-detail.html?project=' + id;
}
document.querySelectorAll('.proj-item').forEach((item, i) => {
  item.style.cursor = 'pointer';
  item.addEventListener('click', () => openDetail(i));
});

                                                    // Smooth scroll
                                                    document.querySelectorAll('a[href^="#"]').forEach(a => {
                                                        a.addEventListener('click', e => { const t = document.querySelector(a.getAttribute('href')); if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth' }); } });
                                                    });
                                            </script>
                                        </body>