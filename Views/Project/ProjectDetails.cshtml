<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Project Detail — Portfolio</title>



<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { cursor: none; overflow-x: hidden; }

  /* Grain */
  body::before { content:''; position:fixed; inset:0; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E"); opacity:.25; pointer-events:none; z-index:1000; }

  ::-webkit-scrollbar { width:3px; }
  ::-webkit-scrollbar-track { background:#2d1b1b; }
  ::-webkit-scrollbar-thumb { background:#BC8F8F; }

  /* Cursor */
  .cursor      { position:fixed; width:10px; height:10px; background:#FFF5EE; border-radius:50%; pointer-events:none; z-index:9999; mix-blend-mode:difference; transition:transform .15s ease; }
  .cursor-ring { position:fixed; width:38px; height:38px; border:1px solid #BC8F8F; border-radius:50%; pointer-events:none; z-index:9998; mix-blend-mode:difference; transition:all .35s cubic-bezier(.25,.46,.45,.94); }
  .cursor.expand      { transform:scale(4); opacity:.3; }
  .cursor-ring.expand { transform:scale(1.5); border-color:#FFF5EE; }

  /* Nav underline */
  .nav-link { position:relative; }
  .nav-link::after { content:''; position:absolute; bottom:-3px; left:0; width:0; height:1px; background:#FFF5EE; transition:width .3s ease; }
  .nav-link:hover::after { width:100%; }

  /* ── PROJECT DETAIL OVERLAY ── */
  .proj-overlay {
    position: fixed; inset: 0; z-index: 200;
    background: #2d1b1b;
    transform: translateX(100%);
    transition: transform .7s cubic-bezier(.77,0,.175,1);
    overflow-y: auto;
    overflow-x: hidden;
  }
  .proj-overlay.open { transform: translateX(0); }

  /* sliding panel bg accent */
  .proj-overlay::before {
    content: '';
    position: fixed; top: 0; left: 0;
    width: 4px; height: 100vh;
    background: linear-gradient(to bottom, #BC8F8F, #8B6565, #BC8F8F);
  }

  /* Close btn */
  .close-btn {
    position: fixed; top: 1.5rem; right: 1.5rem; z-index: 210;
    width: 48px; height: 48px;
    border: 1px solid rgba(188,143,143,.35);
    background: rgba(45,27,27,.9);
    backdrop-filter: blur(10px);
    display: flex; align-items: center; justify-content: center;
    cursor: none;
    transition: all .3s ease;
    color: #c4a090;
    font-size: 1.2rem;
  }
  .close-btn:hover { background: #BC8F8F; color: #FFF5EE; border-color: #BC8F8F; }

  /* Hero image area */
  .proj-hero-img {
    width: 100%; height: clamp(280px, 45vh, 560px);
    position: relative; overflow: hidden;
  }
  .proj-hero-img img {
    width: 100%; height: 100%; object-fit: cover;
    filter: grayscale(15%) contrast(1.05);
    transition: transform .8s ease;
  }
  .proj-overlay.open .proj-hero-img img { transform: scale(1.03); }
  .proj-hero-img::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(45,27,27,.1) 0%, transparent 40%, rgba(45,27,27,.8) 100%);
  }
  /* Big number over hero image */
  .proj-hero-num {
    position: absolute; bottom: -1rem; right: 2rem;
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(6rem, 14vw, 11rem);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(188,143,143,.25);
    pointer-events: none; z-index: 2;
  }
  /* Title over image */
  .proj-hero-title {
    position: absolute; bottom: 2rem; left: 3rem; z-index: 2;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 300;
    color: #FFF5EE;
    line-height: 1;
  }
  .proj-hero-title span { font-style: italic; color: #BC8F8F; }

  /* Section label */
  .det-label {
    font-family: 'DM Mono', monospace;
    font-size: .58rem; letter-spacing: 5px;
    text-transform: uppercase; color: #BC8F8F;
    display: flex; align-items: center; gap: .75rem;
    margin-bottom: 1rem;
  }
  .det-label::before { content:''; width:26px; height:1px; background:#BC8F8F; flex-shrink:0; }

  /* Corner card */
  .corner-card { position: relative; }
  .corner-card::before { content:''; position:absolute; top:-1px; right:-1px; width:40px; height:40px; border-top:2px solid #BC8F8F; border-right:2px solid #BC8F8F; }
  .corner-card::after  { content:''; position:absolute; bottom:-1px; left:-1px; width:40px; height:40px; border-bottom:2px solid #BC8F8F; border-left:2px solid #BC8F8F; }

  /* Buttons */
  .btn-p { display:inline-block; padding:.85rem 2.2rem; background:#BC8F8F; color:#FFF5EE; font-family:'DM Mono',monospace; font-size:.62rem; letter-spacing:3px; text-transform:uppercase; text-decoration:none; border:1px solid #BC8F8F; position:relative; overflow:hidden; transition:color .3s; }
  .btn-p::before { content:''; position:absolute; inset:0; background:#FFF5EE; transform:translateX(-101%); transition:transform .4s cubic-bezier(.77,0,.175,1); }
  .btn-p:hover::before { transform:translateX(0); }
  .btn-p:hover { color:#BC8F8F; }
  .btn-p span { position:relative; z-index:1; }
  .btn-g { display:inline-flex; align-items:center; gap:.6rem; color:rgba(196,160,144,.6); font-family:'DM Mono',monospace; font-size:.62rem; letter-spacing:3px; text-transform:uppercase; text-decoration:none; transition:color .3s; }
  .btn-g:hover { color:#FFF5EE; }
  .btn-g .arrow { transition:transform .3s; }
  .btn-g:hover .arrow { transform:translateX(5px); }

  /* Reveal animation */
  .reveal { opacity:0; transform:translateY(24px); transition:opacity .6s ease, transform .6s ease; }
  .reveal.visible { opacity:1; transform:translateY(0); }
  .d1 { transition-delay:.08s; } .d2 { transition-delay:.16s; } .d3 { transition-delay:.24s; }

  /* Progress bar */
  .skill-bar-track { height:2px; background:rgba(188,143,143,.2); position:relative; overflow:hidden; }
  .skill-bar-fill { height:100%; background:linear-gradient(90deg,#BC8F8F,#8B6565); width:0; transition:width 1.2s cubic-bezier(.25,.46,.45,.94); }

  /* Timeline dot */
  .timeline-item { position:relative; padding-left:2rem; }
  .timeline-item::before { content:''; position:absolute; left:0; top:.4rem; width:8px; height:8px; border-radius:50%; background:#BC8F8F; }
  .timeline-item::after  { content:''; position:absolute; left:3.5px; top:1.2rem; width:1px; bottom:-1rem; background:linear-gradient(to bottom,rgba(188,143,143,.4),transparent); }
  .timeline-item:last-child::after { display:none; }

  /* Image gallery */
  .gallery-img {
    aspect-ratio:16/9; overflow:hidden; position:relative;
    border:1px solid rgba(188,143,143,.2);
  }
  .gallery-img img { width:100%; height:100%; object-fit:cover; filter:grayscale(10%); transition:transform .5s ease, filter .5s ease; }
  .gallery-img:hover img { transform:scale(1.05); filter:grayscale(0%); }
  .gallery-img::after { content:''; position:absolute; inset:0; background:linear-gradient(135deg,rgba(188,143,143,.1),transparent); pointer-events:none; }

  /* Next project link */
  .next-proj {
    border-top:1px solid rgba(188,143,143,.2);
    padding:3rem;
    display:flex; justify-content:space-between; align-items:center;
    cursor:none;
    transition:background .3s;
    text-decoration:none;
  }
  .next-proj:hover { background:rgba(188,143,143,.06); }
  .next-proj .arrow-big { font-size:2rem; color:rgba(196,160,144,.4); transition:all .3s; }
  .next-proj:hover .arrow-big { color:#BC8F8F; transform:translateX(8px); }

  /* Keyframes */
  @@keyframes fadeUp { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
  @@keyframes fadeIn { from{opacity:0} to{opacity:1} }

  /* Mobile */
  @@media(max-width:600px){
    body { cursor:auto; }
    .cursor,.cursor-ring { display:none; }
    .proj-hero-title { left:1.5rem; bottom:1.5rem; }
    .close-btn { top:1rem; right:1rem; }
  }
</style>
</head>

