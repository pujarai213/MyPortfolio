    </div>

    <!-- Overview + Problem/Solution -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 mb-16">
      <div class="reveal">
        <p class="det-label">Overview</p>
        <p class="font-mono text-[.7rem] leading-loose text-shell-muted">${p.overview}</p>
      </div>
      <div>
        <div class="reveal d1 mb-8">
